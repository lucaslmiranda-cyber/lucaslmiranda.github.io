body:has(a:hover) #cursor,body:has(button:hover) #cursor{width:20px;height:20px;background:var(--cyan)}
body:has(a:hover) #cursor-ring,body:has(button:hover) #cursor-ring{width:56px;height:56px;border-color:rgba(87,232,255,.5)}
#bg-canvas{position:fixed;inset:0;z-index:0;pointer-events:none}
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;justify-content:space-between;align-items:center;padding:1.25rem 3rem;background:rgba(7,8,16,.75);backdrop-filter:blur(20px) saturate(1.5);border-bottom:1px solid var(--border)}
.nav-logo{font-family:var(--mono);font-size:.85rem;color:var(--lime);letter-spacing:.05em}
.nav-logo span{color:var(--muted)}
.nav-links{display:flex;gap:2.5rem;list-style:none}
.nav-links a{font-family:var(--mono);font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);text-decoration:none;transition:color .2s;position:relative}
.nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:1px;background:var(--lime);transition:width .3s}
.nav-links a:hover{color:var(--lime)}
.nav-links a:hover::after{width:100%}
.nav-progress{position:fixed;top:0;left:0;height:2px;background:var(--lime);z-index:200;width:0%;transition:width .1s linear;box-shadow:0 0 8px var(--lime)}
.hero{position:relative;z-index:1;min-height:100vh;display:flex;align-items:center;padding:7rem 3rem 4rem;max-width:1280px;margin:0 auto}
.hero-inner{max-width:900px}
.hero-tag{display:inline-flex;align-items:center;gap:.6rem;font-family:var(--mono);font-size:.72rem;letter-spacing:.2em;text-transform:uppercase;color:var(--lime);margin-bottom:2rem;opacity:0;animation:slideUp .6s .3s forwards}
.hero-tag .dot{width:6px;height:6px;background:var(--lime);border-radius:50%;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(198,255,87,.4)}50%{opacity:.7;box-shadow:0 0 0 6px rgba(198,255,87,0)}}
.hero h1{font-family:var(--sans);font-weight:900;font-size:clamp(3.5rem,9vw,8.5rem);line-height:.92;letter-spacing:-.04em;margin-bottom:1.5rem;opacity:0;animation:slideUp .7s .45s forwards}
.hero h1 .name-line{display:block;background:linear-gradient(135deg,#fff 30%,var(--lime) 80%);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.hero h1 .role-line{display:block;color:var(--muted);font-size:.52em;letter-spacing:-.02em;margin-top:.3rem}
.hero-desc{font-size:1.05rem;color:var(--muted);max-width:500px;line-height:1.75;margin-bottom:3rem;opacity:0;animation:slideUp .7s .6s forwards}
.hero-desc strong{color:var(--text);font-weight:500}
.hero-cta{display:flex;gap:1rem;flex-wrap:wrap;opacity:0;animation:slideUp .7s .75s forwards}
.btn{display:inline-flex;align-items:center;gap:.5rem;padding:.85rem 2rem;font-family:var(--mono);font-size:.8rem;letter-spacing:.06em;text-decoration:none;border-radius:3px;transition:all .25s;cursor:none}
.btn-lime{background:var(--lime);color:#070810;font-weight:700;border:none;box-shadow:0 0 0 0 rgba(198,255,87,.3)}
.btn-lime:hover{background:#d4ff7a;transform:translateY(-3px);box-shadow:0 0 30px rgba(198,255,87,.35)}
.btn-outline{background:transparent;color:var(--text);border:1px solid var(--border)}
.btn-outline:hover{border-color:var(--lime);color:var(--lime);transform:translateY(-3px)}
.hero-scroll{position:absolute;bottom:3rem;left:3rem;display:flex;align-items:center;gap:1rem;font-family:var(--mono);font-size:.65rem;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);opacity:0;animation:slideUp .7s 1s forwards}
.scroll-line{width:50px;height:1px;background:var(--muted);position:relative;overflow:hidden}
.scroll-line::after{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:var(--lime);animation:scanline 2s 1.5s infinite}
@keyframes scanline{to{left:100%}}
.section{position:relative;z-index:1;max-width:1280px;margin:0 auto;padding:6rem 3rem}
.section-header{display:flex;align-items:center;gap:1.5rem;margin-bottom:4rem}
.section-num{font-family:var(--mono);font-size:.7rem;color:var(--lime);letter-spacing:.2em}
.section-title{font-family:var(--sans);font-weight:700;font-size:clamp(1.8rem,4vw,2.8rem);letter-spacing:-.03em;color:var(--text)}
.section-line{flex:1;height:1px;background:var(--border);max-width:200px}
.divider{position:relative;z-index:1;max-width:1280px;margin:0 auto;padding:0 3rem}
.divider hr{border:none;border-top:1px solid var(--border)}
.sobre-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:5rem;align-items:start}
.sobre-left p{font-size:1rem;color:var(--muted);line-height:1.85;margin-bottom:1.25rem}
.sobre-left p strong{color:var(--text);font-weight:500}
.sobre-left p.lead{font-size:1.2rem;color:var(--text);font-weight:400;line-height:1.7}
.tags-wrap{display:flex;flex-wrap:wrap;gap:.6rem;margin-top:2.5rem}
.tag{padding:.4rem 1rem;border:1px solid var(--border);border-radius:100px;font-family:var(--mono);font-size:.72rem;color:var(--muted);letter-spacing:.05em;transition:all .2s}
.tag:hover{border-color:var(--lime);color:var(--lime)}
.stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.stat-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:2rem;transition:all .25s;position:relative;overflow:hidden}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--lime),var(--cyan));transform:scaleX(0);transform-origin:left;transition:transform .3s}
.stat-card:hover{border-color:rgba(198,255,87,.2);transform:translateY(-4px)}
.stat-card:hover::before{transform:scaleX(1)}
.stat-n{font-family:var(--sans);font-weight:900;font-size:3rem;line-height:1;background:linear-gradient(135deg,var(--lime),var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:.5rem}
.stat-l{font-family:var(--mono);font-size:.68rem;color:var(--muted);letter-spacing:.08em;text-transform:uppercase}
.materias-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem}
.materia-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:2rem;transition:all .3s;position:relative;overflow:hidden;cursor:none}
.materia-card::after{content:'';position:absolute;inset:0;background:radial-gradient(circle at var(--mx,50%) var(--my,50%),rgba(198,255,87,.06) 0%,transparent 60%);opacity:0;transition:opacity .3s}
.materia-card:hover{border-color:rgba(198,255,87,.25);transform:translateY(-6px)}
.materia-card:hover::after{opacity:1}
.materia-icon{width:44px;height:44px;background:linear-gradient(135deg,rgba(198,255,87,.15),rgba(87,232,255,.1));border:1px solid rgba(198,255,87,.2);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;margin-bottom:1.25rem}
.materia-campus{font-family:var(--mono);font-size:.65rem;color:var(--cyan);letter-spacing:.12em;text-transform:uppercase;margin-bottom:.6rem}
.materia-nome{font-family:var(--sans);font-weight:700;font-size:1.1rem;color:var(--text);line-height:1.3;margin-bottom:.75rem}
.materia-desc{font-size:.85rem;color:var(--muted);line-height:1.65}
.materia-turma{display:inline-flex;align-items:center;gap:.35rem;margin-top:1.25rem;font-family:var(--mono);font-size:.65rem;color:var(--muted);letter-spacing:.05em}
.materia-turma::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--lime)}
.formacao-wrap{display:grid;grid-template-columns:1fr 1fr;gap:3rem}
.formacao-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:2.5rem;position:relative;overflow:hidden;transition:all .3s}
.formacao-card:hover{border-color:rgba(198,255,87,.2);transform:translateY(-4px)}
.formacao-card.main{background:linear-gradient(135deg,rgba(198,255,87,.06),rgba(87,232,255,.04));border-color:rgba(198,255,87,.15)}
.formacao-badge{display:inline-flex;align-items:center;gap:.4rem;padding:.3rem .8rem;background:rgba(198,255,87,.1);border:1px solid rgba(198,255,87,.2);border-radius:100px;font-family:var(--mono);font-size:.65rem;color:var(--lime);letter-spacing:.1em;text-transform:uppercase;margin-bottom:1.5rem}
.formacao-card h3{font-family:var(--sans);font-weight:700;font-size:1.3rem;color:var(--text);margin-bottom:.4rem;line-height:1.3}
.formacao-card .inst{font-family:var(--mono);font-size:.78rem;color:var(--cyan);margin-bottom:1rem}
.formacao-card p{font-size:.9rem;color:var(--muted);line-height:1.7}
.formacao-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.75rem;margin-top:1.5rem}
.disc-chip{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:6px;padding:.5rem .7rem;font-size:.72rem;color:var(--muted);text-align:center;line-height:1.3;transition:all .2s}
.disc-chip:hover{border-color:var(--lime);color:var(--lime)}
.contato-wrap{background:linear-gradient(135deg,rgba(198,255,87,.05) 0%,rgba(87,232,255,.04) 50%,rgba(255,87,184,.04) 100%);border:1px solid var(--border);border-radius:20px;padding:5rem 4rem;text-align:center;position:relative;overflow:hidden}
.contato-wrap::before{content:'';position:absolute;top:-80px;left:50%;transform:translateX(-50%);width:400px;height:400px;background:radial-gradient(circle,rgba(198,255,87,.07),transparent 65%);pointer-events:none}
.contato-wrap h2{font-family:var(--sans);font-weight:900;font-size:clamp(2.5rem,5vw,4rem);letter-spacing:-.04em;margin-bottom:1rem}
.contato-wrap h2 span{background:linear-gradient(135deg,var(--lime),var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.contato-wrap .sub{font-size:1rem;color:var(--muted);max-width:420px;margin:0 auto 2.5rem;line-height:1.7}
.social-row{display:flex;justify-content:center;gap:.75rem;flex-wrap:wrap;margin-top:2rem}
.social-btn{display:inline-flex;align-items:center;gap:.6rem;padding:.7rem 1.4rem;border:1px solid var(--border);border-radius:6px;color:var(--muted);text-decoration:none;font-family:var(--mono);font-size:.75rem;letter-spacing:.05em;transition:all .25s;cursor:none}
.social-btn:hover{border-color:var(--lime);color:var(--lime);background:rgba(198,255,87,.05);transform:translateY(-2px)}
.social-btn svg{width:15px;height:15px;fill:currentColor}
footer{position:relative;z-index:1;border-top:1px solid var(--border);padding:2rem 3rem;display:flex;justify-content:space-between;align-items:center;font-family:var(--mono);font-size:.72rem;color:var(--muted)}
footer span{color:var(--lime)}
.reveal{opacity:0;transform:translateY(32px);transition:opacity .65s cubic-bezier(.25,.46,.45,.94),transform .65s cubic-bezier(.25,.46,.45,.94)}
.reveal.in{opacity:1;transform:translateY(0)}
@keyframes slideUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
@media(max-width:900px){nav{padding:1rem 1.5rem}.nav-links{display:none}.hero{padding:7rem 1.5rem 4rem}.section{padding:5rem 1.5rem}.sobre-grid,.formacao-wrap{grid-template-columns:1fr;gap:3rem}.materias-grid{grid-template-columns:1fr 1fr}.contato-wrap{padding:3rem 1.5rem}footer{flex-direction:column;gap:.5rem;text-align:center}.divider{padding:0 1.5rem}#cursor,#cursor-ring{display:none}body{cursor:auto}.btn,.social-btn,.materia-card{cursor:pointer}}
@media(max-width:600px){.materias-grid{grid-template-columns:1fr}.stats-grid{grid-template-columns:1fr 1fr}.formacao-grid{grid-template-columns:1fr 1fr}}
</style>
</head>
