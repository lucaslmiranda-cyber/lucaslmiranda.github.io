body{background:var(--bg);color:var(--text);font-family:var(--sans);overflow-x:hidden;cursor:none}
#cursor{width:12px;height:12px;background:var(--lime);border-radius:50%;position:fixed;top:0;left:0;pointer-events:none;z-index:9999;transition:transform .1s,width .25s,height .25s,background .25s;transform:translate(-50%,-50%)}
